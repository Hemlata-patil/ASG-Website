# Supabase Config
NEXT_PUBLIC_SUPABASE_URL="your-supabase-project-url"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Database URL for Drizzle ORM
# Replace with your actual connection pooler or direct connection string from Supabase
DATABASE_URL="postgresql://postgres.your-project-id:your-db-password@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres"
